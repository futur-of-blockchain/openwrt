From 85a624e20d5419eeb134641ba517207b1b285cac Mon Sep 17 00:00:00 2001
From: Arien Judge <arien.judge@morsemicro.com>
Date: Fri, 12 Jul 2024 17:22:20 +1000
Subject: [PATCH] board: morsemicro: add MorseMicro Artini board

This adds the basic set of board files for Artini, based on the MT7621

Signed-off-by: Arien Judge <arien.judge@morsemicro.com>
---
 arch/mips/dts/Makefile               |   1 +
 arch/mips/dts/morsemicro,artini.dts  | 163 +++++++++++++++++++++++++++
 arch/mips/mach-mtmips/mt7621/Kconfig |  12 ++
 board/morsemicro/artini/Kconfig      |  21 ++++
 board/morsemicro/artini/Makefile     |   3 +
 board/morsemicro/artini/board.c      |   1 +
 board/morsemicro/artini/env          |  23 ++++
 configs/morsemicro_artini_defconfig  | 100 ++++++++++++++++
 8 files changed, 324 insertions(+)
 create mode 100644 arch/mips/dts/morsemicro,artini.dts
 create mode 100644 board/morsemicro/artini/Kconfig
 create mode 100644 board/morsemicro/artini/Makefile
 create mode 100644 board/morsemicro/artini/board.c
 create mode 100644 board/morsemicro/artini/env
 create mode 100644 configs/morsemicro_artini_defconfig

diff --git a/arch/mips/dts/Makefile b/arch/mips/dts/Makefile
index de3e91b803..a4e881f445 100644
--- a/arch/mips/dts/Makefile
+++ b/arch/mips/dts/Makefile
@@ -14,6 +14,7 @@ dtb-$(CONFIG_BOARD_COMTREND_CT5361) += comtrend,ct-5361.dtb
 dtb-$(CONFIG_BOARD_COMTREND_VR3032U) += comtrend,vr-3032u.dtb
 dtb-$(CONFIG_BOARD_COMTREND_WAP5813N) += comtrend,wap-5813n.dtb
 dtb-$(CONFIG_BOARD_HUAWEI_HG556A) += huawei,hg556a.dtb
+dtb-$(CONFIG_BOARD_MORSEMICRO_ARTINI) += morsemicro,artini.dtb
 dtb-$(CONFIG_BOARD_MT7620_RFB) += mediatek,mt7620-rfb.dtb
 dtb-$(CONFIG_BOARD_MT7620_MT7530_RFB) += mediatek,mt7620-mt7530-rfb.dtb
 dtb-$(CONFIG_BOARD_MT7621_RFB) += mediatek,mt7621-rfb.dtb
diff --git a/arch/mips/dts/morsemicro,artini.dts b/arch/mips/dts/morsemicro,artini.dts
new file mode 100644
index 0000000000..cebb190ad1
--- /dev/null
+++ b/arch/mips/dts/morsemicro,artini.dts
@@ -0,0 +1,163 @@
+// SPDX-License-Identifier: GPL-2.0
+/*
+ * Copyright (C) 2024 Morse Micro
+ *
+ * Author: Arien Judge <arien.judge@morsemicro.com>
+ */
+
+/dts-v1/;
+
+#include "mt7621.dtsi"
+#include <dt-bindings/gpio/gpio.h>
+
+/ {
+	compatible = "morse,artini", "mediatek,mt7621-soc";
+	model = "MorseMicro Artini";
+
+	aliases {
+		serial0 = &uart0;
+		spi0 = &spi;
+	};
+
+	chosen {
+		stdout-path = &uart0;
+	};
+
+	keys {
+		compatible = "gpio-keys";
+
+		reset {
+			label = "reset";
+			gpios = <&gpio0 18 GPIO_ACTIVE_LOW>;
+		};
+	};
+
+	leds {
+		compatible = "gpio-leds";
+
+		led0_red: led0_red {
+			label = "red:led0";
+			gpios = <&gpio0 13 GPIO_ACTIVE_LOW>;
+			default-state = "on";
+		};
+
+		led0_green: led0_green {
+			label = "green:led0";
+			gpios = <&gpio0 14 GPIO_ACTIVE_LOW>;
+			default-state = "off";
+		};
+
+		led0_blue: led0_blue {
+			label = "blue:led0";
+			gpios = <&gpio0 15 GPIO_ACTIVE_LOW>;
+			default-state = "off";
+		};
+
+		led1_red: led1_red {
+			label = "red:led1";
+			gpios = <&gpio0 23 GPIO_ACTIVE_LOW>;
+			default-state = "off";
+		};
+
+		led1_green: led1_green {
+			label = "green:led1";
+			gpios = <&gpio0 22 GPIO_ACTIVE_LOW>;
+			default-state = "off";
+		};
+
+		led1_blue: led1_blue {
+			label = "blue:led1";
+			gpios = <&gpio1 1 GPIO_ACTIVE_LOW>;
+			default-state = "on";
+		};
+
+		led2_red: led2_red {
+			label = "red:led2";
+			gpios = <&gpio0 28 GPIO_ACTIVE_LOW>;
+			default-state = "off";
+		};
+
+		led2_green: led2_green {
+			label = "green:led2";
+			gpios = <&gpio0 29 GPIO_ACTIVE_LOW>;
+			default-state = "on";
+		};
+
+		led2_blue: led2_blue {
+			label = "blue:led2";
+			gpios = <&gpio1 0 GPIO_ACTIVE_LOW>;
+			default-state = "off";
+		};
+	};
+};
+
+&pinctrl {
+	state_default: pin_state {
+		groups = "wdt", "uart3", "jtag", "uart2", "rgmii2";
+		function = "gpio";
+	};
+
+	eth_pins: eth_pins {
+		mdio_pins {
+				groups = "mdio";
+				function = "mdio";
+			};
+		esw_pins {
+			groups = "esw int";
+			function = "esw int";
+		};
+	};
+};
+
+&uart0 {
+	status = "okay";
+};
+
+&gpio {
+	status = "okay";
+};
+
+&spi {
+	status = "okay";
+	num-cs = <2>;
+
+	spi-flash@0 {
+		#address-cells = <1>;
+		#size-cells = <1>;
+		compatible = "jedec,spi-nor";
+		spi-max-frequency = <50000000>;
+		reg = <0>;
+		partitions {
+			compatible = "fixed-partitions";
+			#address-cells = <1>;
+			#size-cells = <1>;
+
+			partition@0 {
+				label = "u-boot";
+				reg = <0x0 0x80000>;
+			};
+
+			partition@80000 {
+				label = "u-boot-env";
+				reg = <0x80000 0x10000>;
+			};
+
+			partition@90000 {
+				label = "factory";
+				reg = <0x90000 0x10000>;
+			};
+
+			partition@A0000 {
+				label = "firmware";
+				reg = <0xA0000 0x1f60000>;
+			};
+		};
+	};
+};
+
+&eth {
+	/* Just enable reset and mdio pins */
+	pinctrl-names = "default";
+	pinctrl-0 = <&eth_pins>;
+	status = "okay";
+};
diff --git a/arch/mips/mach-mtmips/mt7621/Kconfig b/arch/mips/mach-mtmips/mt7621/Kconfig
index 008a28f991..858a2b54f2 100644
--- a/arch/mips/mach-mtmips/mt7621/Kconfig
+++ b/arch/mips/mach-mtmips/mt7621/Kconfig
@@ -99,6 +99,16 @@ config BOARD_MT7621_NAND_RFB
 	  sockets, 1 RGMII to external GbE PHY, 2 audio jacks (in/out),
 	  JTAG pins and expansion GPIO pins.
 
+config BOARD_MORSEMICRO_ARTINI
+	bool "Morse Micro Artini"
+	help
+	  Morse Micro Artini boards have an MT7621A booting from 32MB SPI-NOR flash.
+	  The boards have 128MB DDR3 RAM.
+	  Between its different peripherals there is an AzureWave AW-HM593 providing
+	  HaLow Wi-Fi connectivity, an RTL8152B providing a connected host with
+	  ethernet over USB. and an MT7603 providing 802.11n Wi-Fi connectivity.
+	  Other peripherals include - 3 RGB LEDs, 2 ethernet ports, and a push button.
+
 endchoice
 
 config SYS_CONFIG_NAME
@@ -113,3 +123,5 @@ config SYS_VENDOR
 	default "mediatek" if BOARD_MT7621_RFB || BOARD_MT7621_NAND_RFB
 
 endif
+
+source "board/morsemicro/artini/Kconfig"
diff --git a/board/morsemicro/artini/Kconfig b/board/morsemicro/artini/Kconfig
new file mode 100644
index 0000000000..8d71961c73
--- /dev/null
+++ b/board/morsemicro/artini/Kconfig
@@ -0,0 +1,21 @@
+if BOARD_MORSEMICRO_ARTINI
+
+config SYS_BOARD
+	default "artini"
+
+config SYS_VENDOR
+	default "morsemicro"
+
+config SYS_CONFIG_NAME
+	default "mt7621"
+
+config DEFAULT_DEVICE_TREE
+	default "morsemicro,artini"
+
+config USE_DEFAULT_ENV_FILE
+	default y
+
+config DEFAULT_ENV_FILE
+	default "morse_artini_env"
+
+endif
diff --git a/board/morsemicro/artini/Makefile b/board/morsemicro/artini/Makefile
new file mode 100644
index 0000000000..db129c5aba
--- /dev/null
+++ b/board/morsemicro/artini/Makefile
@@ -0,0 +1,3 @@
+# SPDX-License-Identifier: GPL-2.0
+
+obj-y += board.o
diff --git a/board/morsemicro/artini/board.c b/board/morsemicro/artini/board.c
new file mode 100644
index 0000000000..cec5940325
--- /dev/null
+++ b/board/morsemicro/artini/board.c
@@ -0,0 +1 @@
+// SPDX-License-Identifier: GPL-2.0
diff --git a/board/morsemicro/artini/env b/board/morsemicro/artini/env
new file mode 100644
index 0000000000..8e66f1b06d
--- /dev/null
+++ b/board/morsemicro/artini/env
@@ -0,0 +1,23 @@
+ipaddr=192.168.12.1
+serverip=192.168.12.2
+loadaddr=0x83000000
+flashaddr=0xbfca0000
+bootcmd=run boot_firmware
+bootconf=config-1
+bootdelay=3
+bootled_red=red:led0
+bootled_green=green:led0
+bootmenu_confirm_return=askenv - Press ENTER to return to menu ; bootmenu 60
+bootmenu_default=0
+bootmenu_delay=3
+bootmenu_title=Artini U-Boot
+bootmenu_0=Run default boot command.=run bootcmd
+bootmenu_1=Boot system via TFTP.=run boot_tftp
+bootmenu_2=Load system via TFTP then write to flash.=run flash_tftp
+bootmenu_3=Reboot.=reset
+bootmenu_4=Reset uboot settings to factory defaults.=run reset_factory ; reset
+boot_tftp=askenv ipaddr Device IP address:; askenv serverip Server IP Address:; askenv bootfile Filename on server:; tftpboot ${loadaddr} ${bootfile} && bootm ${loadaddr}
+boot_firmware=bootm ${flashaddr}
+flash_tftp=askenv ipaddr Device IP address:; askenv serverip Server IP Address:; askenv bootfile Filename on server:; tftpboot ${loadaddr} ${bootfile} && run nor_write_firmware
+reset_factory=mtd erase u-boot-env
+nor_write_firmware=mtd erase firmware && mtd write firmware ${loadaddr}
\ No newline at end of file
